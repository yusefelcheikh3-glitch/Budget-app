<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=0">
    <title>OmniControl</title>
    <link rel="apple-touch-icon" href="https://cdn-icons-png.flaticon.com/512/10452/10452243.png">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <style>
        :root { --bg: #030407; --card: rgba(255, 255, 255, 0.03); --border: rgba(255, 255, 255, 0.08); --accent: #38bdf8; --success: #22c55e; --danger: #ef4444; --text: #f8fafc; }
        * { box-sizing: border-box; margin: 0; padding: 0; font-family: -apple-system, sans-serif; -webkit-tap-highlight-color: transparent !important; }
        html, body { background: var(--bg); color: var(--text); width: 100%; min-height: 100vh; overflow: hidden; position: fixed; }
        input { background: rgba(0,0,0,0.3); border: 1px solid var(--border); border-radius: 12px; padding: 14px; color: white; margin-bottom: 8px; font-size: 16px; width: 100%; -webkit-user-select: text !important; }
        .app { width: 100%; max-width: 480px; height: 100vh; display: flex; flex-direction: column; gap: 15px; padding: 15px; }
        .glass { background: var(--card); backdrop-filter: blur(20px); border: 1px solid var(--border); border-radius: 20px; padding: 20px; }
        .balance { font-size: 3rem; font-weight: 900; text-align: center; margin: 5px 0; }
        .progress-bg { background: rgba(255,255,255,0.05); height: 12px; border-radius: 10px; overflow: hidden; border: 1px solid var(--border); margin-top: 10px; }
        .progress-fill { background: linear-gradient(90deg, var(--accent), #818cf8); height: 100%; width: 0%; transition: 0.5s ease-out; }
        .tab-bar { display: flex; gap: 5px; background: var(--card); padding: 5px; border-radius: 14px; }
        .tab { flex: 1; padding: 12px; border-radius: 10px; text-align: center; font-size: 0.75rem; font-weight: 700; cursor: pointer; color: #64748b; }
        .active-tab { background: var(--accent); color: #000; }
        .btn { border-radius: 12px; padding: 16px; font-weight: 800; border: none; width: 100%; text-transform: uppercase; background: var(--accent); color: #000; }
        .hidden { display: none; }
        .tx-list { flex: 1; overflow-y: auto; padding-bottom: 20px; }
        .tx-item { display: flex; justify-content: space-between; padding: 12px; border-bottom: 1px solid var(--border); }
    </style>
</head>
<body>
<div class="app">
    <div class="glass">
        <div class="balance" id="total">$0.00</div>
        <div class="progress-bg"><div class="progress-fill" id="p-bar"></div></div>
        <div style="display:flex; justify-content:space-between; font-size:0.7rem; margin-top:5px; opacity:0.5;"><span id="g-name">Goal</span><span id="g-pct">0%</span></div>
    </div>
    <div class="tab-bar">
        <div class="tab active-tab" id="btn-log" onclick="nav('log')">Spend</div>
        <div class="tab" id="btn-work" onclick="nav('work')">Work</div>
        <div class="tab" id="btn-goal" onclick="nav('goal')">Goal</div>
        <div class="tab" id="btn-history" onclick="nav('history')">History</div>
    </div>
    <div class="tx-list">
        <section id="s-log" class="glass">
            <input type="text" id="desc" placeholder="What did you buy?">
            <input type="number" id="amt" placeholder="Amount">
            <button class="btn" onclick="add(-1)">Deduct from Balance</button>
        </section>
        <section id="s-work" class="glass hidden">
            <input type="number" id="rate" placeholder="Hourly Rate ($)">
            <input type="number" id="hrs" placeholder="Hours Worked">
            <button class="btn" onclick="add(1)">Add to Balance</button>
        </section>
        <section id="s-goal" class="glass hidden">
            <input type="text" id="gn" placeholder="Target Name">
            <input type="number" id="gt" placeholder="Target Amount ($)">
            <button class="btn" onclick="setG()">Update Goal</button>
        </section>
        <section id="s-history" class="glass hidden"><div id="list"></div></section>
    </div>
</div>
<script>
    let db = JSON.parse(localStorage.getItem('omni_v4')) || { logs: [], goal: { name: 'New Tech', target: 500 } };
    function nav(t) {
        document.querySelectorAll('section').forEach(s => s.classList.add('hidden'));
        document.querySelectorAll('.tab').forEach(b => b.classList.remove('active-tab'));
        document.getElementById('s-'+t).classList.remove('hidden');
        document.getElementById('btn-'+t).classList.add('active-tab');
    }
    function add(m) {
        const d = document.getElementById('desc').value || 'Work';
        const val = m < 0 ? parseFloat(document.getElementById('amt').value) : (parseFloat(document.getElementById('hrs').value) * (parseFloat(document.getElementById('rate').value) || 25));
        if(!val) return;
        db.logs.unshift({ d, a: val * m });
        render(); nav('history');
        document.querySelectorAll('input').forEach(i => i.value = '');
    }
    function setG() {
        db.goal.name = document.getElementById('gn').value || db.goal.name;
        db.goal.target = parseFloat(document.getElementById('gt').value) || db.goal.target;
        render(); nav('log');
    }
    function render() {
        let s = 0; document.getElementById('list').innerHTML = '';
        db.logs.forEach(l => { s += l.a; document.getElementById('list').innerHTML += `<div class="tx-item"><b>${l.d}</b><span style="color:${l.a>0?'var(--success)':'var(--danger)'}">${l.a>0?'+':''}${l.a.toFixed(2)}</span></div>`; });
        document.getElementById('total').innerText = '$' + s.toFixed(2);
        let p = Math.min(Math.max((s / db.goal.target) * 100, 0), 100);
        document.getElementById('p-bar').style.width = p + '%';
        document.getElementById('g-name').innerText = db.goal.name;
        document.getElementById('g-pct').innerText = Math.floor(p) + '%';
        localStorage.setItem('omni_v4', JSON.stringify(db));
    }
    render();
</script>
</body>
</html>
